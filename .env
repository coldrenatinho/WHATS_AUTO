GEMINI_API_KEY=

# ─── Evolution API (WhatsApp) ──────────────────────────────────
# URL pública (com SSL)
EVOLUTION_SERVER_URL=https://evolution.nortemtsistemas.com.br
EVOLUTION_API_KEY=jslKx7DZ635slSIBhR5v51k6tcQZHD4j
# Segredo de validacao para inbound webhook (recomendado diferente da API key)
EVOLUTION_WEBHOOK_SECRET=lL3uga6yFvH2JX0H5L7kO1ZQSBEQScqo
# Nome da instância criada na Evolution API
EVOLUTION_INSTANCE=meu_whatsapp

# ─── Revolution API (Integração no Backend) ───────────────────
# mock = usa dados simulados em memória | real = chama API externa
REVOLUTION_API_MODE=real
# Se vazio, backend usa EVOLUTION_SERVER_URL
REVOLUTION_API_URL=
# Se vazio, backend usa EVOLUTION_API_KEY
REVOLUTION_API_KEY=
# Endpoints customizáveis (opcional)
REVOLUTION_ENDPOINT_LIST=/instance/fetchInstances
REVOLUTION_ENDPOINT_CREATE=/instance/create
REVOLUTION_ENDPOINT_CONNECT=/instance/connect/{instanceName}
REVOLUTION_ENDPOINT_DISCONNECT=/instance/logout/{instanceName}
REVOLUTION_ENDPOINT_STATUS=/instance/connectionState/{instanceName}
REVOLUTION_ENDPOINT_QRCODE=/instance/connect/{instanceName}
REVOLUTION_ENDPOINT_SEND_TEXT=/message/sendText/{instanceName}

