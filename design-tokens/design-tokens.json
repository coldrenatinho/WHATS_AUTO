      "mono": "'Courier New', monospace"
    },
    "scale": {
      "xs": {
        "fontSize": 12,
        "lineHeight": 16,
        "letterSpacing": 0.5,
        "fontWeight": 400,
        "name": "Extra Small"
      },
      "sm": {
        "fontSize": 14,
        "lineHeight": 20,
        "letterSpacing": 0,
        "fontWeight": 400,
        "name": "Small"
      },
      "base": {
        "fontSize": 16,
        "lineHeight": 24,
        "letterSpacing": 0,
        "fontWeight": 400,
        "name": "Base"
      },
      "lg": {
        "fontSize": 18,
        "lineHeight": 28,
        "letterSpacing": 0,
