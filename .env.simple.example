# Copie para .env.simple e ajuste o minimo necessario.

# Portas publicas do servidor
APP_PORT=80
EVOLUTION_PORT=8080
NODE_EXPORTER_PORT=9100
CADVISOR_PORT=8081

# URL publica da Evolution, se houver dominio ou proxy externo.
# Para teste local, pode manter localhost.
EVOLUTION_PUBLIC_URL=http://localhost:8080

# Origens permitidas pelo backend.
# Se usar dominio, exemplo: https://chat.seudominio.com.br,https://seudominio.com.br
ALLOWED_ORIGINS=http://localhost,http://127.0.0.1

# Banco principal da aplicacao
DB_NAME=whatsauto
DB_USER=whatsauto
DB_PASS=troque_esta_senha
DB_ROOT_PASS=troque_esta_senha_root

# Banco interno da Evolution API
POSTGRES_USER=evolution
POSTGRES_PASSWORD=troque_esta_senha_evolution
POSTGRES_DB=evolution

# Segredos
# JWT_SECRET precisa ter pelo menos 32 caracteres.
JWT_SECRET=troque_este_jwt_secret_com_mais_de_32_chars
EVOLUTION_API_KEY=troque_esta_chave_evolution
EVOLUTION_WEBHOOK_SECRET=troque_esta_chave_evolution

# Primeiro usuario criado no bootstrap
BUSINESS_NAME=WhatsAuto
COMPANY_SUBDOMAIN=default
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123456
ADMIN_RESET_PASSWORD=true

# Integrações opcionais
REVOLUTION_API_MODE=real
N8N_WEBHOOK_URL=
TYPEBOT_BUILDER_URL=https://app.typebot.io/typebots
MESSAGE_SEND_MAX_ATTEMPTS=3

# Operacao
BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_SECONDS=86400
