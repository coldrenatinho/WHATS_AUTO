# ═══════════════════════════════════════════════════════════════
#   WHATSAUTO - WhatsApp Chatbot Multi-Tenant
#   Norte MT Sistemas - https://nortemtsistemas.com.br
#   Copie este arquivo para .env e preencha os valores
# ═══════════════════════════════════════════════════════════════

# ─── App Config ────────────────────────────────────────────────
NODE_ENV=production
API_URL=https://api.nortemtsistemas.com.br
ROOT_DOMAIN=nortemtsistemas.com.br
ACME_EMAIL=seu-email@exemplo.com
ALLOWED_ORIGINS=https://nortemtsistemas.com.br,https://api.nortemtsistemas.com.br,https://n8n.nortemtsistemas.com.br,https://evolution.nortemtsistemas.com.br

# ─── MariaDB (Banco Principal) ────────────────────────────────
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=whatsauto
DB_USER=whatsauto
DB_PASS=whatsauto123
DB_ROOT_PASS=root_super_secret_password

# ─── JWT ───────────────────────────────────────────────────────
JWT_SECRET=sua_chave_jwt_super_secreta_minimo_32_chars
DB_SYNC_ON_STARTUP=true

# ─── n8n ────────────────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=troque_por_senha_forte_aqui
N8N_HOST=n8n.nortemtsistemas.com.br
WEBHOOK_URL=https://n8n.nortemtsistemas.com.br

# ─── Google Gemini (IA) ────────────────────────────────────────
# Obtenha GRÁTIS em: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ─── Evolution API (WhatsApp) ──────────────────────────────────
# URL pública (com SSL)
EVOLUTION_SERVER_URL=https://evolution.nortemtsistemas.com.br
EVOLUTION_API_KEY=chave_secreta_evolution_aqui_minimo_20_chars
# Segredo de validacao para inbound webhook (recomendado diferente da API key)
EVOLUTION_WEBHOOK_SECRET=segredo_webhook_evolution_minimo_20_chars
# Nome da instância criada na Evolution API
EVOLUTION_INSTANCE=meu_whatsapp

# ─── Revolution API (Integração no Backend) ───────────────────
# mock = usa dados simulados em memória | real = chama API externa
REVOLUTION_API_MODE=real
# Se vazio, backend usa EVOLUTION_SERVER_URL
REVOLUTION_API_URL=
# Se vazio, backend usa EVOLUTION_API_KEY
REVOLUTION_API_KEY=
# Endpoints customizáveis (opcional)
REVOLUTION_ENDPOINT_LIST=/instance/fetchInstances
REVOLUTION_ENDPOINT_CREATE=/instance/create
REVOLUTION_ENDPOINT_CONNECT=/instance/connect/{instanceName}
REVOLUTION_ENDPOINT_DISCONNECT=/instance/logout/{instanceName}
REVOLUTION_ENDPOINT_STATUS=/instance/connectionState/{instanceName}
REVOLUTION_ENDPOINT_QRCODE=/instance/connect/{instanceName}
REVOLUTION_ENDPOINT_SEND_TEXT=/message/sendText/{instanceName}

# ─── Bot Config ────────────────────────────────────────────────
# Nome do negócio (aparece no prompt da IA)
BUSINESS_NAME=Norte MT Sistemas
# Subdomínio da empresa principal para bootstrap inicial no banco
COMPANY_SUBDOMAIN=norte
ALLOWED_ORIGINS=https://nortemtsistemas.com.br,https://api.nortemtsistemas.com.br,https://n8n.nortemtsistemas.com.br,https://evolution.nortemtsistemas.com.br,https://chat.nortemtsistemas.com.br
HUMAN_PHONE=5566999999999

# ─── Admin Inicial (persistido no MariaDB no primeiro start) ────
ADMIN_NAME=Administrador
ADMIN_EMAIL=admin@nortemtsistemas.com.br
ADMIN_PASSWORD=troque_esta_senha_admin_com_12_chars
ADMIN_RESET_PASSWORD=false

# ─── PostgreSQL (usado pela Evolution API) ─────────────────────
POSTGRES_USER=botuser
POSTGRES_PASSWORD=bot_senha_forte_aqui
POSTGRES_DB=evolution_db