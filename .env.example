# ══════════════════════════════════════════════════════
#   BOT WHATSAPP COM IA — VARIÁVEIS DE AMBIENTE
#   Copie este arquivo para .env e preencha os valores
# ══════════════════════════════════════════════════════

# ─── n8n ────────────────────────────────────────────
N8N_USER=admin
N8N_PASSWORD=troque_por_senha_forte_aqui
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# ─── Google Gemini ──────────────────────────────────
# Obtenha GRÁTIS em: https://aistudio.google.com/apikey
GEMINI_API_KEY=AIza...

# ─── Evolution API ──────────────────────────────────
# URL interna (Docker) ou externa (ngrok/VPS)
EVOLUTION_SERVER_URL=http://evolution:8080
EVOLUTION_API_KEY=chave_secreta_evolution_aqui_minimo_20_chars
# Nome da instância criada na Evolution API
EVOLUTION_INSTANCE=meu_whatsapp

# ─── Bot Config ─────────────────────────────────────
# Nome do negócio (aparece no prompt da IA)
BUSINESS_NAME=AutoCars Premium
# Telefone do atendente humano (com código do país, sem +)
# Quando o bot transferir, envia notificação para este número
HUMAN_PHONE=5511999999999

# ─── PostgreSQL (usado pela Evolution API) ──────────
POSTGRES_USER=botuser
POSTGRES_PASSWORD=bot_senha_forte_aqui
POSTGRES_DB=evolution_db
